<UserControl x:Class="LectorGlobalApp.SearchableComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="45" d:DesignWidth="200"
             Name="Root">

    <Grid>
        <ToggleButton x:Name="BtnToggle" Height="45" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource SidebarBorderBg}" BorderThickness="1" Cursor="Hand" Click="BtnToggle_Click">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtSelected" Text="{Binding ElementName=Root, Path=SelectedItem}" Foreground="{DynamicResource TextMain}" FontSize="14" VerticalAlignment="Center" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                            <!-- Chevron Icon -->
                            <Path x:Name="IconChevron" Data="M 0 0 L 5 5 L 10 0" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent" Stretch="None" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="IconChevron" Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <Popup x:Name="PopupList" IsOpen="{Binding ElementName=BtnToggle, Path=IsChecked, Mode=TwoWay}" StaysOpen="False" PlacementTarget="{Binding ElementName=BtnToggle}" Placement="Bottom" Width="{Binding ElementName=BtnToggle, Path=ActualWidth}" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="5">
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource SidebarBorderBg}" BorderThickness="1" CornerRadius="8" MaxHeight="300" Margin="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Search Box -->
                    <Border Grid.Row="0" BorderBrush="{DynamicResource SidebarBorderBg}" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Search Icon (Magnifying Glass) -->
                            <Path Data="M 12 12 L 17 17 M 14 8 A 6 6 0 1 0 2 8 A 6 6 0 1 0 14 8 Z" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtSearch" Grid.Column="1" Background="Transparent" Foreground="{DynamicResource TextMain}" BorderThickness="0" FontSize="14" VerticalAlignment="Center" TextChanged="TxtSearch_TextChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        <TextBlock x:Name="Placeholder" Text="{Binding ElementName=Root, Path=SearchPlaceholder}" Foreground="{DynamicResource TextMuted}" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                    
                    <!-- List -->
                    <ListBox x:Name="LstItems" Grid.Row="1" Background="Transparent" BorderThickness="0" ItemsSource="{Binding ElementName=Root, Path=FilteredItems}" SelectedItem="{Binding ElementName=Root, Path=SelectedItem, Mode=TwoWay}" SelectionChanged="LstItems_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="5">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SidebarHoverBg}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SidebarActiveBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="14"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
